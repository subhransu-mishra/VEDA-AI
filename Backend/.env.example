PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/veda
JWT_SECRET=replace_with_strong_secret
GEMINI_API_KEY=replace_with_gemini_key

# Frontend URL and CORS
FRONTEND_URL=deployed_frontend_url_here
# Comma-separated list of allowed browser origins in production.
# Example: https://veda-ai-one-psi.vercel.app,https://your-preview.vercel.app
CORS_ORIGINS=deployed_frontend_url_here

# Cloudinary (required for doctor verification uploads)
CLOUDINARY_CLOUD_NAME=replace_with_cloud_name
CLOUDINARY_API_KEY=replace_with_api_key
CLOUDINARY_API_SECRET=replace_with_api_secret

# Optional: override default demo admin credentials.
# Format: [{"email":"admin@vedaai.com","password":"Admin@123","name":"Super Admin"}]
ADMIN_CREDENTIALS_JSON=[]
